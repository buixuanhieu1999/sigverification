# Optional overrides. Defaults already point to these project-relative files.
SIGNATURE_ENCODER_MODEL=models/gpds_signature_encoder.onnx
DOCUMENT_DETECTOR_MODEL=models/document_detector.onnx
SIGNATURE_DETECTOR_MODEL=models/signature_detector.onnx
# Required only when a replacement encoder has no embedded threshold metadata.
# SIGNATURE_THRESHOLD=0.3709427153002471
EMBEDDING_BATCH_SIZE=8
SIGNATURE_ORT_PROVIDER=auto
SIGNATURE_RATE=80
SIGNATURE_CONFIDENCE=0.50
SIGNATURE_PADDING=0
SIGNATURE_SHRINK=0
SIGNATURE_QUERY_TOP_CUT=0.35
SIGNATURE_KEEP_LARGEST_INK_GROUPS=3
SIGNATURE_MAX_FILES_PER_SIDE=20
SIGNATURE_MAX_UPLOAD_MB=20
SIGNATURE_MAX_TOTAL_UPLOAD_MB=100
SIGNATURE_MAX_IMAGE_MEGAPIXELS=40
SIGNATURE_API_HOST=0.0.0.0
SIGNATURE_API_PORT=8000
